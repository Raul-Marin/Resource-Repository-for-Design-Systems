            'Settings': '<path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/>'
        };

        function renderLucideIcon(iconName) {
            const svgPath = lucideIcons[iconName];
            if (!svgPath) return '';
            return `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" xmlns="http://www.w3.org/2000/svg">${svgPath}</svg>`;
        }

        // Render all Lucide icons
        document.addEventListener('DOMContentLoaded', function() {
            const iconCards = document.querySelectorAll('.icon-card[data-icon]');
            iconCards.forEach(card => {
                const iconName = card.getAttribute('data-icon');
                const preview = card.querySelector('.icon-preview.lucide-icon');
                if (preview && lucideIcons[iconName]) {
                    preview.innerHTML = renderLucideIcon(iconName);
                }
            });
        });

        function copyToClipboard(button, text) {
            navigator.clipboard.writeText(text).then(() => {
                const originalText = button.textContent;
                button.textContent = 'Copied!';
                button.style.background = '#10b981';
                button.style.color = 'white';
                button.style.borderColor = '#10b981';
                setTimeout(() => {
                    button.textContent = originalText;
                    button.style.background = '#f3f4f6';
                    button.style.color = '#374151';
                    button.style.borderColor = '#e5e7eb';
                }, 1500);
            });
        }
    </script>
</body>
</html>
