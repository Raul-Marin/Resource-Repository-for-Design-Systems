                            <path d="M14 10.5C16.1338 10.5 17.5 9.18154 17.5 6C17.5 9.18154 18.8567 10.5 22 10.5C18.8567 10.5 17.5 11.8567 17.5 15C17.5 11.8567 16.1338 10.5 14 10.5Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
