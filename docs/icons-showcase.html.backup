                    <div class="icon-card">
                        <div class="icon-preview lucide-icon"></div>
                        <div class="icon-name">Save</div><div class="icon-card" data-icon="Save">
                        <div class="icon-preview lucide-icon"></div>ide</span>
                        <button class="copy-button" onclick="copyToClipboard(this, 'Save')">Copy Name</button>
                    </div>
                    <div class="icon-card">
                        <div class="icon-preview lucide-icon"></div>
                        <div class="icon-name">Upload</div>
